<% if session.recording_url.present? %>
  <video class="lookout-manager__preview"
         src="<%= session.recording_url %>"
         muted
         loop
         playsinline
         controls></video>
<% end %>

<div class="lookout-manager__row-info">
  <div class="lookout-manager__row-meta">
    <span class="lookout-manager__row-duration"><%= format_recording_duration(session.duration_seconds) %></span>
    <span class="lookout-manager__row-date"><%= session.created_at.strftime("%b %-d") %></span>
  </div>
</div>

<div class="lookout-manager__row-form">
  <%= form_with url: forward_heartbeats_project_lookout_session_path(@project, session),
                method: :post,
                id: "assign-form-#{session.id}" do |f| %>
    <input type="hidden"
           name="project_name"
           data-lookout-manager-target="projectNameField">

    <div class="lookout-manager__destination">
      <label class="lookout-manager__dest">
        <input type="radio" name="lookout-dest-<%= session.id %>" value="existing"
               class="lookout-manager__dest-radio"
               data-action="change->lookout-manager#destinationChanged"
               <%= "checked" unless hackatime_project_names.empty? %>
               <%= "disabled" if hackatime_project_names.empty? %>>
        <span class="lookout-manager__dest-text">
          <span class="lookout-manager__dest-name">Add to an existing Hackatime project</span>
          <% if hackatime_project_names.any? %>
            <% linked_names = Array(linked_hackatime_names) %>
            <% times = hackatime_times || {} %>
            <select class="lookout-manager__dest-select"
                    data-lookout-manager-target="existingSelect"
                    data-action="change->lookout-manager#destinationChanged focus->lookout-manager#selectExisting">
              <% if linked_names.any? %>
                <optgroup label="Linked to this project">
                  <% linked_names.each do |name| %>
                    <% secs = times[name] || 0; h = secs / 3600; m = (secs % 3600) / 60 %>
                    <option value="<%= name %>"><%= name %> (<%= h %>h<%= m %>m)</option>
                  <% end %>
                </optgroup>
                <% other_names = hackatime_project_names - linked_names %>
                <% if other_names.any? %>
                  <optgroup label="Your other projects">
                    <% other_names.each do |name| %>
                      <% secs = times[name] || 0; h = secs / 3600; m = (secs % 3600) / 60 %>
                      <option value="<%= name %>"><%= name %> (<%= h %>h<%= m %>m)</option>
                    <% end %>
                  </optgroup>
                <% end %>
              <% else %>
                <% hackatime_project_names.each do |name| %>
                  <% secs = times[name] || 0; h = secs / 3600; m = (secs % 3600) / 60 %>
                  <option value="<%= name %>"><%= name %> (<%= h %>h<%= m %>m)</option>
                <% end %>
              <% end %>
            </select>
          <% else %>
            <span class="lookout-manager__dest-sub">You don't have any Hackatime projects yet.</span>
          <% end %>
        </span>
      </label>

      <label class="lookout-manager__dest">
        <input type="radio" name="lookout-dest-<%= session.id %>" value="new"
               class="lookout-manager__dest-radio"
               data-action="change->lookout-manager#destinationChanged"
               <%= "checked" if hackatime_project_names.empty? %>>
        <span class="lookout-manager__dest-text">
          <span class="lookout-manager__dest-name">Create a new Hackatime project</span>
          <input type="text"
                 class="lookout-manager__dest-input"
                 data-lookout-manager-target="newName"
                 data-action="input->lookout-manager#newNameChanged focus->lookout-manager#selectNew"
                 value="<%= default_hackatime_name %>"
                 placeholder="Project name"
                 maxlength="120"
                 autocomplete="off"
                 disabled>
        </span>
      </label>
    </div>

  <% end %>

  <div class="lookout-manager__row-actions">
    <%= render ActionButtonComponent.new(text: "Assign", variant: :primary, size: :small, type: :submit, form: "assign-form-#{session.id}") %>
    <%= button_to "Delete permanently",
          skip_project_lookout_session_path(@project, session),
          method: :post,
          class: "action-btn action-btn--small action-btn--destructive",
          form: { data: { turbo_confirm: "Remove this recording without sending time to Hackatime? This can't be undone.", turbo_stream: true } } %>
  </div>
</div>
